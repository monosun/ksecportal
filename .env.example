DB_ROOT_PASSWORD=rootpassword
DB_USER=secportal
DB_PASSWORD=secportal123
JWT_SECRET=your-256-bit-secret-key-change-in-production-must-be-32-chars-min
JWT_EXPIRATION=86400000
JASYPT_ENCRYPTOR_PASSWORD=your-master-key

# CORS — 프론트엔드 오리진 목록 (쉼표 구분)
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:80

# Email (optional — scheduler skips send when MAIL_PASSWORD is empty)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=noreply@example.com
MAIL_PASSWORD=

# 서버 URL (승인 이메일 내 링크에 사용)
APP_BASE_URL=https://your-domain.com/api
